# =============================================================================
# Do NOT ignore the following project metadata
# =============================================================================
#
# CCS project files should be committed:
#   .project
#   .cproject
#   .ccsproject
#   .settings/
#   targetConfigs/
#   *.syscfg
#
# STM32 project files should be committed:
#   *.ioc
#   CMakeLists.txt
#   CMakePresets.json
#   cmake/
#
